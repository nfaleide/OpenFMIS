# Test environment — used by pytest and docker-compose.test.yml
DATABASE_URL=postgresql+asyncpg://openfmis_test:openfmis_test@localhost:5433/openfmis_test

JWT_SECRET_KEY=test-secret-key-not-for-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=5
JWT_REFRESH_TOKEN_EXPIRE_DAYS=1

CORS_ORIGINS=["http://localhost:3000"]

APP_ENV=test
APP_DEBUG=true
APP_LOG_LEVEL=DEBUG
